          font-family: 'Pin Sans';
          src: url('https://s.pinimg.com/webapp/Pin-Sans-MacOS-Bold-ce475d98.woff2') format('woff2');
          font-weight: 700;
        }

        body, button, input, select, textarea {
          font-family: var(--base-font-family-default-latin) !important;
        }

