t="Pinterest" name="application-name"><meta content="#ffffff" name="msapplication-TileColor"><meta content="https://s.pinimg.com/webapp/logo_transparent_144x144-3da7a67b.png" name="msapplication-TileImage"><meta content="origin" name="referrer"><meta content="274266067164" property="fb:app_id"><meta content="Pinterest" property="og:site_name"><script type="text/javascript" async="" charset="utf-8" src="./jupe3_files/recaptcha__fr.js.téléchargement" crossorigin="anonymous" integrity="sha384-DrNESJBiw3/5EviXAjqXZ95LaS9ZTmLT4FMEw7JeMD7w3qIY4O5ZrBQoStcTgjIS" nonce=""></script><script id="recaptcha-enterprise-src" src="./jupe3_files/enterprise.js.téléchargement"></script><script nonce="">
          let cspReportsCount = 0;
          document.addEventListener('securitypolicyviolation', async (event) => {
            if (event.originalPolicy.includes('report-uri') || cspReportsCount >= 500) {
              return;
            }
            cspReportsCount += 1;
            await fetch('/_/_/csp_report/', {
              method: 'POST',
              body: JSON.stringify({
                'csp-report': {
                  'blocked-uri': event.blockedURI,
                  'column-number': event.columnNumber,
                  disposition: event.disposition,
                  'document-uri': event.documentURI,
                  'effective-directive': event.effectiveDirective,
                  'line-number': event.lineNumber,
                  'original-policy': event.originalPolicy,
                  referrer: event.referrer,
                  sample: event.sample,
                  'source-file': event.sourceFile,
                  'status-code': event.statusCode,
                  'violated-directive': event.violatedDirective,
                  'is-metatag': true,
                },
              }),
            });
          });
      </script><link href="./jupe3_files/82121-296171dc1f088ea3.css" rel="stylesheet"><link href="./jupe3_files/AuthDesktopCSSImports-64ad0aa73a40d13f.css" rel="stylesheet"><style id="pins-sans-font">@font-face {
